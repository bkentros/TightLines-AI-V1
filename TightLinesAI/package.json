{
  "name": "tightlinesai",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "start:dev-client": "CI=0 expo start --dev-client --host lan",
    "start:dev-client:8081": "CI=0 expo start --dev-client --host lan --port 8081",
    "start:dev-client:clear": "CI=0 expo start --dev-client --host lan --clear",
    "start:dev-client:tunnel": "bash scripts/start-metro-localtunnel.sh",
    "start:dev-client:tunnel:clear": "EXPO_START_CLEAR=1 bash scripts/start-metro-localtunnel.sh",
    "start:dev-client:tunnel:expo": "CI=0 expo start --dev-client --tunnel",
    "start:dev-client:with-tunnel-host": "bash scripts/expo-metro-via-tunnel-host.sh",
    "start:dev-client:localtunnel": "bash scripts/start-metro-localtunnel.sh",
    "start:dev-client:ngrok": "bash scripts/start-metro-ngrok.sh",
    "generate:us-city-index": "node scripts/generate-us-city-index.mjs",
    "audit:how-fishing": "deno run --allow-read --allow-write scripts/audit/run-full-audit.ts",
    "audit:how-fishing:march-august": "deno run --allow-read --allow-write scripts/audit/run-full-audit.ts --months=3,4,5,6,7,8",
    "audit:how-fishing:remaining": "deno run --allow-read --allow-write scripts/audit/run-full-audit.ts --months=1,2,9,10,11,12",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo-google-fonts/bricolage-grotesque": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "^2.99.0",
    "expo": "~55.0.5",
    "expo-apple-authentication": "~55.0.8",
    "expo-asset": "~55.0.8",
    "expo-audio": "~55.0.8",
    "expo-camera": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-dev-client": "~55.0.13",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.11",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.11",
    "expo-router": "~55.0.4",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "ngrok": "^5.0.0-beta.2",
    "react": "19.2.0",
    "react-dom": "^19.2.4",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "patch-package": "^8.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
