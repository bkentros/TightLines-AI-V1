{
  "expo": {
    "name": "FinFindr",
    "slug": "tightlines-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.finseekr.tightlinesai",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIDesignRequiresCompatibility": true,
        "NSLocalNetworkUsageDescription": "FinFindr connects to the Metro dev server on your Mac over Wi‑Fi while you develop.",
        "NSBonjourServices": [
          "_expo._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0a1628"
      },
      "package": "com.finseekr.tightlinesai"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FinFindr uses your location to auto-fill weather, tide, and moon conditions for better fishing recommendations."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FinFindr uses your camera to photograph catches and upload water images for AI analysis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FinFindr accesses your photos to upload water images and catch photos."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "FinFindr uses your microphone to record voice fishing logs."
        }
      ],
      "expo-notifications",
      "expo-apple-authentication",
      "expo-local-authentication",
      "expo-asset",
      "expo-font",
      "expo-image"
    ],
    "scheme": "tightlinesai",
    "extra": {
      "eas": {
        "projectId": "fbe2fc29-e0ac-49f0-a755-5a7c5f233d31"
      }
    }
  }
}
