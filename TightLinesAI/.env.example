# Copy to .env and fill in (never commit .env).
# Expo / Supabase client (app)
# EXPO_PUBLIC_SUPABASE_URL=https://hsesngprhpgajyfbrwbf.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI — local Deno scripts only (e.g. npm run gen:recommender-tackle-images).
# Do NOT prefix with EXPO_PUBLIC_; that would expose the key in the mobile bundle.
# OPENAI_API_KEY=

# Water Reader — local ops only (same values as Supabase Edge secrets where noted)
# Get project URL from the Supabase dashboard if needed.
# SUPABASE_URL=https://hsesngprhpgajyfbrwbf.supabase.co
# Must match the Edge Function secret (see Dashboard → Edge Functions → Secrets, or `supabase secrets list`).
# WATER_READER_INTERNAL_KEY=
