{
  "pack_name": "tightlines_v1_engine_golden_test_scenarios",
  "version": "1.0.0",
  "description": "Implementation-ready fixture pack for validating the TightLines AI V1 deterministic engine.",
  "score_band_ranges": {
    "poor": [
      0,
      34
    ],
    "fair": [
      35,
      54
    ],
    "good": [
      55,
      74
    ],
    "great": [
      75,
      100
    ]
  },
  "global_rules": {
    "confirmed_context_first": true,
    "manual_freshwater_temp_overrides_inferred": true,
    "manual_freshwater_temp_confidence": "very_high",
    "observed_salt_brackish_temp_confidence": "high",
    "inferred_freshwater_temp_confidence_depends_on_stability": true,
    "moon_solunar_role": "mostly_window_shaping_not_primary_final_score_driver",
    "strong_suppression_can_cap_opportunity": true,
    "v1_honesty_forbidden_claims": [
      "exact fish depth",
      "exact spawning stage",
      "exact species behavior",
      "guaranteed catch outcomes",
      "exact structure/positioning beyond broad context language"
    ]
  },
  "regression_checks": [
    {
      "id": "manual_temp_should_raise_confidence",
      "scenarios": [
        "scenario_03",
        "scenario_15"
      ],
      "assertion": "manual freshwater temp scenarios should show higher confidence than similar inferred-temp freshwater scenarios"
    },
    {
      "id": "tide_dominates_in_salt_and_brackish",
      "scenarios": [
        "scenario_09",
        "scenario_10",
        "scenario_11",
        "scenario_12",
        "scenario_13",
        "scenario_17",
        "scenario_18"
      ],
      "assertion": "movement/tide should visibly outrank other drivers more often than in freshwater scenarios"
    },
    {
      "id": "river_and_lake_narration_must_differ",
      "scenarios": [
        "scenario_06",
        "scenario_07",
        "scenario_08",
        "scenario_16"
      ],
      "assertion": "river scenarios should not sound like stillwater reports; lake scenarios should not sound like current-driven river reports"
    },
    {
      "id": "solunar_cannot_rescue_bad_days",
      "scenarios": [
        "scenario_02",
        "scenario_08",
        "scenario_17"
      ],
      "assertion": "decent or strong solunar should not override major suppression"
    },
    {
      "id": "stable_transition_beats_unstable_front",
      "scenarios": [
        "scenario_05",
        "scenario_02"
      ],
      "assertion": "scenario_05 should clearly outscore scenario_02"
    },
    {
      "id": "moving_water_beats_dead_slack_heat",
      "scenarios": [
        "scenario_09",
        "scenario_10"
      ],
      "assertion": "scenario_09 should clearly outscore scenario_10"
    },
    {
      "id": "storm_threat_caps_good_tide",
      "scenarios": [
        "scenario_17"
      ],
      "assertion": "scenario_17 must not rate good/great purely from tide and solunar alignment"
    }
  ],
  "scenarios": [
    {
      "id": "scenario_01",
      "slug": "freshwater_lake_upper_midwest_early_spring_warming",
      "title": "Upper Midwest early-spring lake warming, stable recovery",
      "purpose": "Validate that the engine recognizes an improving freshwater lake setup in a northern climate without overstating pre-spawn precision.",
      "input": {
        "environment_mode": "freshwater_lake",
        "region": "great_lakes_upper_midwest",
        "calendar_timing": "early_april",
        "recent_air_pattern": "5\u20137 days of gradual warming after a colder stretch",
        "water_temp_source": "inferred",
        "water_temp_character": "still cool, but trending upward",
        "pressure_trend": "stable_to_slightly_rising",
        "wind_speed": "light_to_moderate",
        "cloud_cover": "partly_cloudy",
        "precipitation": "none_active",
        "solunar_support": "moderate",
        "time_of_day_setup": "best overlap around late morning into early afternoon"
      },
      "expected": {
        "seasonal_state": [
          "transition_warming"
        ],
        "confidence_band": [
          "moderate"
        ],
        "score_band": [
          "good"
        ],
        "expected_window_shape": "one improving main window centered after the cold early morning lag",
        "primary_drivers": [
          "warming_trend",
          "improving_stability",
          "tolerable_wind",
          "usable_light_conditions"
        ],
        "primary_suppressors": [
          "still_cool_water",
          "inferred_temp_uncertainty",
          "slow_early_day_start"
        ],
        "narrative_must_include": [
          "improving trend language",
          "fish should be more responsive later than very early",
          "conditions are better than recent colder days"
        ],
        "narrative_must_not_include": [
          "exact spawn language",
          "exact depth claims",
          "guaranteed aggressive bite language"
        ]
      }
    },
