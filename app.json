{
  "expo": {
    "name": "TightLines AI",
    "slug": "tightlines-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.finseekr.tightlinesai",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1628"
      },
      "package": "com.finseekr.tightlinesai"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TightLines AI uses your location to auto-fill weather, tide, and moon conditions for better fishing recommendations."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "TightLines AI uses your camera to photograph catches and upload water images for AI analysis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TightLines AI accesses your photos to upload water images and catch photos."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "TightLines AI uses your microphone to record voice fishing logs."
        }
      ],
      "expo-notifications"
    ],
    "scheme": "tightlinesai",
    "extra": {
      "eas": {
        "projectId": "fbe2fc29-e0ac-49f0-a755-5a7c5f233d31"
      }
    }
  }
}
